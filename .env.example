# Environment Configuration Example
# Copy this to .env and fill in your actual values

# Robotics Platform
ROBOT_TYPE=G1
ROBOT_BODY_ID=

# API Keys
DASHSCOPE_API_KEY=sk-xxxxx
OPENAI_API_KEY=

# System
DEBUG=False
LOG_LEVEL=INFO

# Paths (optional, defaults to ~/robot_self_control/)
# DATA_DIR=
# SKILLS_DIR=
# GENERATED_CODE_DIR=
# LOGS_DIR=
